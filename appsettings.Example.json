{
  "$schema": "http://json.schemastore.org/appsettings.json",
  "_comment": "This is a comprehensive example showing all Serilog configuration options",
  
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.Debug" ],
    
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.AspNetCore.Hosting": "Information",
        "Microsoft.AspNetCore.Routing": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    
    "WriteTo": [
      {
        "_comment": "Console output for real-time monitoring",
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz}] [{Level:u3}] {SourceContext}{NewLine}{Message:lj}{NewLine}{Exception}",
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console"
        }
      },
      {
        "_comment": "General application logs - daily rotation",
        "Name": "File",
        "Args": {
          "path": "Logs/PrivacyConfirmed-.log",
          "rollingInterval": "Day",
          "rollOnFileSizeLimit": true,
          "fileSizeLimitBytes": 10485760,
          "retainedFileCountLimit": 30,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz}] [{Level:u3}] [{SourceContext}] [Thread:{ThreadId}] [Machine:{MachineName}] {Message:lj}{NewLine}{Exception}",
          "shared": false,
          "flushToDiskInterval": "00:00:01"
        }
      },
      {
        "_comment": "Error-only logs - kept longer for troubleshooting",
        "Name": "File",
        "Args": {
          "path": "Logs/PrivacyConfirmed-Errors-.log",
          "rollingInterval": "Day",
          "restrictedToMinimumLevel": "Error",
          "rollOnFileSizeLimit": true,
          "fileSizeLimitBytes": 10485760,
          "retainedFileCountLimit": 90,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz}] [{Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}{NewLine}----------{NewLine}",
          "shared": false
        }
      },
      {
        "_comment": "Warning logs - separate file for warnings",
        "Name": "File",
        "Args": {
          "path": "Logs/PrivacyConfirmed-Warnings-.log",
          "rollingInterval": "Day",
          "restrictedToMinimumLevel": "Warning",
          "levelSwitch": {
            "$controlledBy": "Serilog.LevelSwitch"
          },
          "rollOnFileSizeLimit": true,
          "fileSizeLimitBytes": 5242880,
          "retainedFileCountLimit": 60,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz}] [{Level:u3}] {Message:lj}{NewLine}",
          "shared": false
        }
      },
      {
        "_comment": "Debug output for Visual Studio debugging",
        "Name": "Debug",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss}] [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    
    "Enrich": [ 
      "FromLogContext", 
      "WithMachineName", 
      "WithThreadId",
      "WithProcessId",
      "WithEnvironmentName"
    ],
    
    "Properties": {
      "Application": "PrivacyConfirmed",
      "Environment": "Development"
    },
    
    "Filter": [
      {
        "_comment": "Filter out noisy health check logs",
        "Name": "ByExcluding",
        "Args": {
          "expression": "RequestPath like '/health%'"
        }
      },
      {
        "_comment": "Filter out static file requests",
        "Name": "ByExcluding",
        "Args": {
          "expression": "RequestPath like '/css%' or RequestPath like '/js%' or RequestPath like '/images%'"
        }
      }
    ]
  },
  
  "_LoggingOptions": {
    "_description": "Explanation of common configuration options",
    "_rollingInterval": "Options: Infinite, Year, Month, Day, Hour, Minute",
    "_fileSizeLimitBytes": "10485760 = 10 MB, 52428800 = 50 MB, 104857600 = 100 MB",
    "_logLevels": "Verbose, Debug, Information, Warning, Error, Fatal",
    "_outputTemplateTokens": {
      "Timestamp": "Log event timestamp",
      "Level": "Log level (u3 = uppercase 3-char)",
      "Message": "Log message (lj = JSON escape)",
      "Exception": "Exception details",
      "Properties": "Custom properties",
      "NewLine": "Line break",
      "SourceContext": "Logger category/class name",
      "ThreadId": "Thread identifier",
      "MachineName": "Machine name",
      "ProcessId": "Process ID",
      "EnvironmentName": "Environment (Dev/Prod)"
    }
  },
  
  "AllowedHosts": "*",
  
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=PrivacyConfirmedDB;Trusted_Connection=True;TrustServerCertificate=True;",
    "PostgreSQLConnection": "Host=localhost;Database=privacyconfirmedwebsite;Username=webuser;Password=P@ss55word;"
  },
  
  "DatabaseProvider": "PostgreSQL",
  
  "FileUploadSettings": {
    "UploadPath": "UploadedFiles",
    "MaxFileSizeInMB": 10,
    "AllowedExtensions": [ ".zip", ".doc", ".docx", ".xlsx", ".xls" ]
  },
  
  "ApiSettings": {
    "BaseUrl": "https://localhost:7002",
    "Timeout": 30
  }
}
