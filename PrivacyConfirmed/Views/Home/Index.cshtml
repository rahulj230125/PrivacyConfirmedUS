            <div class="code-block" id="code-nodejs">
                <pre>import { PrivacyConfirmed } from '@@privacyconfirmed/node';

const pc = new PrivacyConfirmed({
  domain: 'your-domain.privacyconfirmed.in',
  clientId: process.env.PC_CLIENT_ID,
  clientSecret: process.env.PC_CLIENT_SECRET
});

// Authenticate user
app.post('/login', async (req, res) => {
  const { email, password } = req.body;
  const session = await pc.authenticate({
    email,
    password,
    mfaEnabled: true
  });
  res.json({ token: session.accessToken });
});</pre>
            </div>

            <div class="code-block" id="code-python" style="display: none;">
                <pre>from privacyconfirmed import PrivacyConfirmed

pc = PrivacyConfirmed(
    domain='your-domain.privacyconfirmed.in',
    client_id=os.environ['PC_CLIENT_ID'],
    client_secret=os.environ['PC_CLIENT_SECRET']
)

# Authenticate user
@@app.route('/login', methods=['POST'])
def login():
    data = request.get_json()
    session = pc.authenticate(
        email=data['email'],
        password=data['password'],
        mfa_enabled=True
    )
    return jsonify({'token': session.access_token})</pre>
            </div>

            <div class="code-block" id="code-java" style="display: none;">
                <pre>import com.privacyconfirmed.PrivacyConfirmed;

PrivacyConfirmed pc = new PrivacyConfirmed.Builder()
    .domain("your-domain.privacyconfirmed.in")
    .clientId(System.getenv("PC_CLIENT_ID"))
    .clientSecret(System.getenv("PC_CLIENT_SECRET"))
    .build();

// Authenticate user
@@PostMapping("/login")
public ResponseEntity&lt;Map&lt;String, String&gt;&gt; login(@@RequestBody LoginRequest req) {
    Session session = pc.authenticate(
        req.getEmail(),
        req.getPassword(),
        true  // MFA enabled
    );
    return ResponseEntity.ok(Map.of("token", session.getAccessToken()));
}</pre>
            </div>

            <div class="code-block" id="code-go" style="display: none;">
                <pre>import "github.com/privacyconfirmed/go-sdk"

pc := privacyconfirmed.New(privacyconfirmed.Config{
    Domain:       "your-domain.privacyconfirmed.in",
    ClientID:     os.Getenv("PC_CLIENT_ID"),
    ClientSecret: os.Getenv("PC_CLIENT_SECRET"),
})

// Authenticate user
func login(w http.ResponseWriter, r *http.Request) {
    var req LoginRequest
    json.NewDecoder(r.Body).Decode(&req)

    session, err := pc.Authenticate(privacyconfirmed.AuthRequest{
        Email:      req.Email,
        Password:   req.Password,
        MFAEnabled: true,
    })

    json.NewEncoder(w).Encode(map[string]string{
        "token": session.AccessToken,
    })
}</pre>
