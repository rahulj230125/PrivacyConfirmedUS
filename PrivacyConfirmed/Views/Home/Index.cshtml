@{
    ViewData["Title"] = "Enterprise Identity & Access Management | PrivacyConfirmed";
}

<div class="hero-section text-center bg-primary text-white py-5">
    <div class="container">
        <h1 class="display-4">Secure Identity Management for Modern Enterprises</h1>
        <p class="lead">Enterprise-grade authentication and authorization with India-first data residency</p>
        <div class="mt-4">
            @* Use Url.Action for MVC controller actions *@
            <a href="@Url.Action("ReqADemo", "Home")" class="btn btn-light btn-lg mx-2">Request Demo</a>
            <a href="/trial" class="btn btn-outline-light btn-lg mx-2">Start Free Trial</a>
        </div>
    </div>
</div>

<div class="overview-section py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
                <p class="lead mb-4">At PrivacyConfirmed, we deliver a next-generation Identity Access Management (IAM) solution designed to meet the dual needs of enterprise-grade security and developer-friendly integration.</p>
                <p class="lead mb-4">
                    Enterprises today face increasing regulatory pressures, growing user expectations, and rapidly evolving cyber threats. With our IAM platform, you get <b>standards-compliant authentication and authorization</b> built on OIDC and OAuth2, ensuring interoperability with modern apps, APIs, and third-party systems.
                </p>
                <p class="lead mb-4">
                    Our solution provides <b>Single Sign-On (SSO)</b> for seamless user experiences, <b>multi-factor authentication (MFA)</b> for risk-based security, and  <b>fine-grained access control (RBAC)</b> to protect sensitive data. For developers, we offer SDKs, clear documentation, and pre-built integrations to get apps running in hours—not weeks.
                </p>
                <p class="lead mb-4">
                    Whether you’re a <b>CTO focused on compliance, a product manager delivering user experience, a security architect enforcing policies</b>, or a <b>developer integrating OAuth flows</b>, PrivacyConfirmed IAM delivers the clarity, compliance, and confidence you need.
                </p>
                <p class="lead mb-4">
                    Scale with trust. Build with speed. Deploy with peace of mind.
                </p>
                <a href="@Url.Action("WhyChoose", "Home")" class="btn btn-primary mb-5">Learn Why Companies Choose Us</a>
            </div>
        </div>
    </div>
</div>

<div class="features-overview py-5 bg-light">
    <div class="container">
        <div class="row">
            <div class="col-md-6">
                <h2 class="mb-4">Enterprise-Grade IAM Platform</h2>
                <p>Our solution provides:</p>
                <ul class="feature-list">
                    <li>Standards-compliant authentication with OIDC and OAuth2</li>
                    <li>Seamless Single Sign-On (SSO) experiences</li>
                    <li>Multi-factor authentication (MFA) for enhanced security</li>
                    <li>Fine-grained access control (RBAC)</li>
                </ul>
            </div>
            <div class="col-md-6">
                <h2 class="mb-4">Developer-Focused Integration</h2>
                <p>Get your apps running in hours with:</p>
                <ul class="feature-list">
                    <li>Comprehensive SDKs for major platforms</li>
                    <li>Clear, practical documentation</li>
                    <li>Pre-built components and examples</li>
                    <li>Local support in your timezone</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="core-features py-5">
    <div class="container">
        <h2 class="text-center mb-4">Core Features</h2>
        <div class="row">
            <div class="col-md-4 mb-4">
                <h3 class="h4">Authentication & SSO</h3>
                <ul class="list-unstyled">
                    <li>✓ OIDC/OAuth 2.0 Compliant</li>
                    <li>✓ Single Sign-On</li>
                    <li>✓ Social Login Integration</li>
                </ul>
            </div>
            <div class="col-md-4 mb-4">
                <h3 class="h4">Advanced Security</h3>
                <ul class="list-unstyled">
                    <li>✓ Multi-Factor Authentication</li>
                    <li>✓ Risk-Based Authentication</li>
                    <li>✓ Fraud Detection</li>
                </ul>
            </div>
            <div class="col-md-4 mb-4">
                <h3 class="h4">Enterprise Controls</h3>
                <ul class="list-unstyled">
                    <li>✓ Role-Based Access Control</li>
                    <li>✓ Audit Logging</li>
                    <li>✓ Compliance Reporting</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="case-study py-5 bg-light">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h2>Trusted by Leading Indian Enterprises</h2>
                <p class="lead">A leading fintech company reduced their authentication costs by 40% while maintaining complete data residency in India. With our local support team and INR pricing, they achieved compliance and enhanced security within budget.</p>
                <a href="/case-studies" class="btn btn-primary">Read More Success Stories</a>
            </div>
            <div class="col-md-6">
                <img src="/images/india-map-coverage.svg" alt="Map showing PrivacyConfirmed's coverage across India" class="img-fluid" />
            </div>
        </div>
    </div>
</div>

<div class="cta-section py-5 bg-primary text-white">
    <div class="container text-center">
        <h2>Ready to Secure Your Enterprise?</h2>
        <p class="lead">Start your free trial today or schedule a demo with our solutions team</p>
        <p class="mb-4">Scale with trust. Build with speed. Deploy with peace of mind.</p>
        <div class="mt-4">
            <a href="/contact" class="btn btn-light btn-lg mx-2">Contact Sales</a>
            <a href="/docs" class="btn btn-outline-light btn-lg mx-2">View Documentation</a>
        </div>
    </div>
</div>
