@{
    ViewData["Title"] = "How Its Helps | PrivacyConfirmed";
}

<div class="hero-section">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 mx-auto text-center">
                <h1>How Its Helps</h1>
                <p class="lead mb-4">How Its Helps</p>
            </div>
        </div>
    </div>
</div>

<div class="container py-5">
    <div class="row">
        <div class="col-lg-3">
            <nav class="nav flex-column sticky-top pt-4" style="top: 2rem;">
                <a class="nav-link" href="#Developers">Developers</a>
                <a class="nav-link" href="#Security-Compliance">Security & Compliance</a>
                <a class="nav-link" href="#Product-UX-Teams">Product/UX Teams</a>
            </nav>
        </div>
        
        <div class="col-lg-9">
            <section id="Developers" class="mb-5">
                
                <div class="card mb-4 fade-in">
                    <div class="card-header bg-primary text-white">
                        <h3 class="h5 mb-0">Developers</h3>
                    </div>
                    <div class="card-body">
                        <div class="mb-4">
                            <strong class="d-block mb-2">Outcome:Faster integration and development</strong>
                            <p>
                                With PrivacyConfirmed IAM, developers can integrate authentication and authorization systems quickly and securely. Our SDKs and detailed documentation reduce the complexity of OAuth2 and OIDC, ensuring that developers spend less time on security concerns and more time on building features.
                            </p>
                            <ul>
                                <li>Access to pre-built integrations for popular platforms (e.g., social login, SSO).</li>
                                <li>Seamless support for OAuth flows, enabling fast app scaling.</li>
                                <li>Clear API documentation and example code snippets to speed up integration.</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </section>

            <section id="Security-Compliance" class="mb-5">
                <div class="card mb-4 fade-in">
                    <div class="card-header bg-primary text-white">
                        <h3 class="h5 mb-0">Security & Compliance</h3>
                    </div>
                    <div class="card-body">
                        <div class="mb-4">
                            <strong class="d-block mb-2">Outcome:Regulatory compliance made easy</strong>
                            <p>
                                Security architects and compliance officers benefit from PrivacyConfirmed IAM's robust security features and standards compliance (e.g., ISO, SOC). With fine-grained access control (RBAC), MFA, and audit logs, ensuring compliance with local data residency and global regulations is simple and straightforward.
                            </p>
                            <ul>
                                <li>Secure role-based access control to protect sensitive data.</li>
                                <li>Real-time audit trails for detailed reporting and compliance.</li>
                                <li>India-based data residency and local support to meet regulatory standards.</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </section>

            <section id="Product-UX-Teams" class="mb-5">
                <div class="card mb-4 fade-in">
                    <div class="card-header bg-primary text-white">
                        <h3 class="h5 mb-0">Product/UX Teams</h3>
                    </div>
                    <div class="card-body">
                        <div class="mb-4">
                            <strong class="d-block mb-2">Outcome:Improved user experience</strong>
                            <p>
                                For product managers and UX designers, PrivacyConfirmed IAM offers SSO and social login to simplify the user journey, reducing friction and increasing conversion rates. The admin console and observability tools give teams the power to fine-tune user access and make data-driven decisions, improving overall product usability.
                            </p>
                            <ul>
                                <li>Seamless authentication for a better user experience with SSO and MFA.</li>
                                <li>Simple role management for different user types, ensuring ease of use.</li>
                                <li>Clear visibility into authentication events and user behavior to optimize the experience.</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </section>

            <section id="security" class="mb-5">
                <h2 class="mb-4">Security Best Practices</h2>
                <div class="card fade-in">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <h4>Token Security</h4>
                                <ul class="list-unstyled">
                                    <li>? Use short-lived access tokens</li>
                                    <li>? Implement token rotation</li>
                                    <li>? Store tokens securely</li>
                                    <li>? Never expose tokens in URLs</li>
                                </ul>
                            </div>
                            <div class="col-md-6 mb-4">
                                <h4>Application Security</h4>
                                <ul class="list-unstyled">
                                    <li>? Implement PKCE for mobile/SPA</li>
                                    <li>? Use secure session management</li>
                                    <li>? Enable MFA for sensitive operations</li>
                                    <li>? Regular security audits</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </div>
</div>