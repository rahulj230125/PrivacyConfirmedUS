@page
@model PrivacyConfirmed.Models.CoreFeaturesModel
@{
    ViewData["Title"] = "Core Features";
}

<section class="pc-hero">
    <div class="pc-container">
        <div class="pc-hero__content">
            <p class="pc-eyebrow">PrivacyConfirmed IAM</p>
            <h1 class="pc-h1">Core Features</h1>
            <p class="pc-subtitle">
                Standards-based identity for modern applications—secure, scalable, and developer-friendly.
                Centralize authentication, policies, and access control without slowing teams down.
            </p>

            <div class="pc-cta-row">
                <a class="pc-btn pc-btn--primary" href="/Contact">Talk to us</a>
                <a class="pc-btn pc-btn--ghost" href="/Docs">View docs</a>
            </div>
        </div>
    </div>
</section>

<section class="pc-section">
    <div class="pc-container">
        <div class="pc-grid">
            @foreach (var card in Model.FeatureCards)
            {
                <article class="pc-card">
                    <div class="pc-card__icon">
                        <img src="@card.IconPath" alt="@card.IconAlt" loading="lazy" />
                    </div>
                    <h3 class="pc-card__title">@card.Title</h3>
                    <p class="pc-card__desc">@card.Description</p>
                </article>
            }
        </div>
    </div>
</section>

<section class="pc-section pc-section--alt">
    <div class="pc-container pc-footer-cta">
        <div>
            <h2 class="pc-h2">Build fast. Secure everything.</h2>
            <p class="pc-subtitle">
                From startups to enterprises, PrivacyConfirmed gives you control, clarity, and confidence
                in every authentication decision.
            </p>
        </div>
        <div class="pc-cta-row">
            <a class="pc-btn pc-btn--primary" href="/Contact">Get started</a>
            <a class="pc-btn pc-btn--ghost" href="/Pricing">See pricing</a>
        </div>
    </div>
</section>
