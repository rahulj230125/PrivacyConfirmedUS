@{
    ViewData["Title"] = "Admin & Dev Console Overview | PrivacyConfirmed";
}

<div class="hero-section">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 mx-auto text-center">
                <h1>Admin & Dev Console Overview</h1>
                <p class="lead mb-4">Admin & Dev Console Overview</p>
            </div>
        </div>
    </div>
</div>
<div class="container py-5">
    <div class="row">
        <div class="col-lg-3">
            <nav class="nav flex-column sticky-top pt-4" style="top: 2rem;">
                <a class="nav-link" href="#admin-console">Admin Console</a>
                <a class="nav-link" href="#developer-console">Developer Console</a>
                <a class="nav-link" href="#next-steps">Next Steps</a>
            </nav>
        </div>
        <div class="col-lg-9">
            <section id="admin-console" class="mb-5">
                <div class="card mb-4 fade-in">
                    <div class="card-header bg-primary text-white">
                        <h3 class="h5 mb-0">Admin Console</h3>
                    </div>
                    <div class="card-body">
                        <p>
                            The <b>Admin Console</b> is designed to give security and system administrators complete control over identity management, user access, and policy enforcement. With this tool, you can manage users, roles, and authentication settings in a centralized, easy-to-use interface.
                        </p>
                        <div class="mb-4">
                            <strong class="d-block mb-2">Key Features:</strong>
                            <ul class="list-group-horizontal">
                                <li><b>User Management:</b> View and manage users, assign roles, and adjust access privileges</li>
                                <li><b>Role-Based Access Control (RBAC):</b> Configure and assign permissions to specific user roles for secure access</li>
                                <li><b>Audit Logs:</b> Track all authentication and authorization events to ensure full compliance and provide transparency</li>
                            </ul>
                        </div>
                        <div class="mb-4">
                            <p><b>1.	User Management Screen: </b>Easily view and manage user accounts, assign roles, and grant or revoke access.</p>
                            <p><i>Screenshot of the user management interface, showing a list of users with filter options for roles and activity status.</i></p>
                            <img src="/images/admin-console-user-management.png" 
                                 alt="User management screen displaying users, their roles, and account activity statuses in PrivacyConfirmed Admin Console." 
                                 class="img-fluid mb-3">

                            <p><b>2.	Roles & Policies Screen:</b>Create custom roles and apply security policies based on organizational needs.</p>
                            <p><i>Screenshot of the screen where admins configure roles and policies, with options to create new roles and apply access controls.</i></p>
                            <img src="/images/admin-console-roles-and-policies.png"
                                 alt="Admin console screen showing role and policy management, with options to define and apply user permissions."
                                 class="img-fluid mb-3">

                            <p><b>3.	Audit Logs Screen:</b>Monitor all system access and authentication events to ensure full visibility into your system.</p>
                            <p><i>Audit logs screen showing user access events and system changes for compliance tracking.</i></p>
                            <img src="/images/admin-console-audit-log.png"
                                 alt="Audit logs screen showing user access events and system changes for compliance tracking."
                                 class="img-fluid mb-3">
                        </div>
                    </div>
                </div>
            </section>
            <section id="developer-console" class="mb-5">
                <div class="card mb-4 fade-in">
                    <div class="card-header bg-primary text-white">
                        <h3 class="h5 mb-0">Developer Console</h3>
                    </div>
                    <div class="card-body">
                        <p>
                            The <b>Developer Console</b> Console is designed for developers to easily integrate PrivacyConfirmed IAM with applications. It provides access to OAuth settings, SDKs, and code examples for quick integration into web and mobile apps.
                        </p>
                        <div class="mb-4">
                            <strong class="d-block mb-2">Key Features:</strong>
                            <ul class="list-group-horizontal">
                                <li><b>OAuth Configuration:</b> Set up and manage OAuth2 client configurations for your app</li>
                                <li><b>SDK Downloads:</b> Download SDKs and libraries for integrating authentication flows into your mobile and web applications</li>
                                <li><b>Code Samples:</b> Access code snippets for different OAuth2 grant types to simplify your integration</li>
                            </ul>
                        </div>
                        <div class="mb-4">
                            <p><b>1.	OAuth Settings Screen: </b>Configure OAuth2 settings, manage client credentials, and set redirect URIs to ensure seamless integration.</p>
                            <p><i>Screenshot of OAuth settings page showing client IDs, client secrets, and redirect URI configuration.</i></p>
                            <img src="/images/admin-console-oauth-settings.png"
                                 alt="OAuth settings screen displaying client credentials and redirect URI configuration for PrivacyConfirmed IAM."
                                 class="img-fluid mb-3">

                            <p><b>2.	SDKs & Documentation Screen:</b>“Download SDKs for web and mobile apps, and access complete documentation to speed up development.”</p>
                            <p><i>Screenshot of the SDK download page, showing available libraries for different platforms with download buttons.</i></p>
                            <img src="/images/admin-console-sdk-documentation.png"
                                 alt="Developer console screen displaying SDK options for web and mobile app integration in PrivacyConfirmed IAM."
                                 class="img-fluid mb-3">

                            <p><b>3.	Code Samples Screen:</b>Browse code examples for Authorization Code Flow, Client Credentials Flow, and more to accelerate your app’s authentication process.</p>
                            <p><i>Screenshot of code samples section with example snippets for OAuth2 flows like Authorization Code and Client Credentials.</i></p>
                            <img src="/images/admin-console-code-sample.png"
                                 alt="Code samples screen showing example snippets for OAuth2 grant types in PrivacyConfirmed IAM"
                                 class="img-fluid mb-3">
                        </div>
                    </div>
                </div>
            </section>
            <section id="next-steps" class="mb-5">
                <div class="card mb-4 fade-in">
                    <div class="card-header bg-primary text-white">
                        <h3 class="h5 mb-0">Next Steps for Admin & Developer Console</h3>
                    </div>
                    <div class="card-body">
                        <div class="mb-4">
                            <ul class="list-group-horizontal">
                                <li><b>Admin Console:</b> Manage users, enforce security policies, and track compliance with detailed audit logs</li>
                                <li><b>Developer Console:</b> Set up OAuth configurations, download SDKs, and access documentation to integrate IAM features seamlessly</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </section>
            <!--Below section is irrelevant and can be removed but when I remove the section above this disappear-->
            <section id="security" class="mb-5">
                <h2 class="mb-4">Security Best Practices</h2>
                <div class="card fade-in">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <h4>Token Security</h4>
                                <ul class="list-unstyled">
                                    <li>? Use short-lived access tokens</li>
                                    <li>? Implement token rotation</li>
                                    <li>? Store tokens securely</li>
                                    <li>? Never expose tokens in URLs</li>
                                </ul>
                            </div>
                            <div class="col-md-6 mb-4">
                                <h4>Application Security</h4>
                                <ul class="list-unstyled">
                                    <li>? Implement PKCE for mobile/SPA</li>
                                    <li>? Use secure session management</li>
                                    <li>? Enable MFA for sensitive operations</li>
                                    <li>? Regular security audits</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </div>
</div>