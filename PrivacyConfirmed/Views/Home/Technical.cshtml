    <div class="d-flex justify-content-center">
    <div style="background: #fff; box-shadow: 0 4px 24px rgba(0,0,0,0.10), 0 1.5px 4px rgba(0,0,0,0.08); border-radius: 3rem; padding: 0.5rem 1.5rem; display: inline-block;">
    <ul class="nav nav-pills justify-content-center" style="gap: 0.5rem;">
        <li class="nav-item">
            <a class="round_sub_nav_button_active card active rounded-pill" asp-controller="Technical" asp-action="Technical">Documentation</a>
        </li>
        <li class="nav-item">
            <a class="round_sub_nav_button_in_active rounded-pill" asp-controller="ResourceCenter" asp-action="Index">Resource Center</a>
        </li>
        <li class="nav-item">
            <a class="round_sub_nav_button_in_active rounded-pill" asp-controller="Home" asp-action="FAQ">FAQ</a>
        </li>
