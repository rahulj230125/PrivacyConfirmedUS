@{
    ViewData["Title"] = "Pricing & Feature Comparison | PrivacyConfirmed";
}

<!-- Platform Pills Navigation -->
<div class="container" style="padding-top: 5rem;">
    <div class="d-flex justify-content-center">
        <div style="background: #fff; box-shadow: 0 4px 24px rgba(0,0,0,0.10), 0 1.5px 4px rgba(0,0,0,0.08); border-radius: 3rem; padding: 0.5rem 1.5rem; display: inline-block;">
            <ul class="nav nav-pills" style="gap: 0.5rem;">
                <li class="nav-item">
                    <a class="round_sub_nav_button_in_active rounded-pill" asp-controller="Home" asp-action="CoreFeatures">
                        Core Features
                    </a>
                </li>
                <li class="nav-item">
                    <a class="round_sub_nav_button_in_active rounded-pill" asp-controller="Home" asp-action="ComparisonMatrix">
                        Comparison Matrix
                    </a>
                </li>
                <li class="nav-item">
                    <a class="round_sub_nav_button_in_active rounded-pill" asp-controller="Home" asp-action="WhyChoose">Why Us</a>
                </li>
                <!--li class="nav-item">
                    <a class="round_sub_nav_button_in_active rounded-pill" asp-controller="Home" asp-action="LegalAndCompliance">
                        Legal & Compliance
                    </a>
                </li-->
                <li class="nav-item">
                    <a class="round_sub_nav_button_in_active rounded-pill" asp-controller="Home" asp-action="HowItHelps">How It Helps</a>
                </li>
                <li class="nav-item">
                    <a class="round_sub_nav_button_active card active rounded-pill" asp-controller="Home" asp-action="Pricing">Pricing</a>
                </li>
            </ul>
        </div>
    </div>
</div>

<div class="container py-3">
    <h1 class="text-center mb-5">Feature Comparison</h1>

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle shadow-sm" style="background: #fff; border-radius: 1rem; overflow: hidden;">
            <thead class ="table-comp_matrix">
                <tr>
                    <th>Features</th>
                    <th>PrivacyConfirmed</th>
                    <th>Global Provider A</th>
                    <th>Global Provider B</th>
                    <th>Local Provider</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>OAuth/OIDC Standards</td>
                    <td><i class="bi bi-check-circle-fill text-success"></i> Full</td>
                    <td><i class="bi bi-check-circle-fill text-success"></i> Full</td>
                    <td><i class="bi bi-check-circle-fill text-success"></i> Full</td>
                    <td><i class="bi bi-dash-circle text-warning"></i> Partial</td>
                </tr>
                <tr>
                    <td>India Data Residency</td>
                    <td><i class="bi bi-check-circle-fill text-success"></i> Built-in</td>
                    <td><i class="bi bi-dash-circle text-warning"></i> Additional Cost</td>
                    <td><i class="bi bi-x-circle text-danger"></i> No</td>
                    <td><i class="bi bi-check-circle-fill text-success"></i> Yes</td>
                </tr>
                <tr>
                    <td>Enterprise SSO</td>
                    <td><i class="bi bi-check-circle-fill text-success"></i> Unlimited</td>
                    <td><i class="bi bi-check-circle-fill text-success"></i> Tiered</td>
                    <td><i class="bi bi-check-circle-fill text-success"></i> Tiered</td>
                    <td><i class="bi bi-dash-circle text-warning"></i> Basic</td>
                </tr>
                <tr>
                    <td>Social Login Providers</td>
                    <td><i class="bi bi-check-circle-fill text-success"></i> 20+</td>
                    <td><i class="bi bi-check-circle-fill text-success"></i> 30+</td>
                    <td><i class="bi bi-check-circle-fill text-success"></i> 25+</td>
                    <td><i class="bi bi-dash-circle text-warning"></i> 5+</td>
                </tr>
                <tr>
                    <td>Developer SDKs</td>
                    <td><i class="bi bi-check-circle-fill text-success"></i> All Major</td>
                    <td><i class="bi bi-check-circle-fill text-success"></i> All Major</td>
                    <td><i class="bi bi-check-circle-fill text-success"></i> All Major</td>
                    <td><i class="bi bi-dash-circle text-warning"></i> Limited</td>
                </tr>
                <tr>
                    <td>Local Support</td>
                    <td><i class="bi bi-check-circle-fill text-success"></i> 24/7 India</td>
                    <td><i class="bi bi-dash-circle text-warning"></i> Limited</td>
                    <td><i class="bi bi-dash-circle text-warning"></i> Limited</td>
                    <td><i class="bi bi-check-circle-fill text-success"></i> India</td>
                </tr>
                <tr>
                    <td>INR Billing</td>
                    <td><i class="bi bi-check-circle-fill text-success"></i> Yes</td>
                    <td><i class="bi bi-x-circle text-danger"></i> No</td>
                    <td><i class="bi bi-x-circle text-danger"></i> No</td>
                    <td><i class="bi bi-check-circle-fill text-success"></i> Yes</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="pricing-cards mt-5">
        <h2 class="text-center mb-4">Pricing Plans</h2>
        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="card">
                    <div class="card-header">
                        <h3 class="text-center">Startup</h3>
                    </div>
                    <div class="card-body">
                        <h4 class="text-center mb-3">?15,000<small>/month</small></h4>
                        <ul class="list-unstyled">
                            <li>? Up to 10,000 MAU</li>
                            <li>? 5 Social Login Providers</li>
                            <li>? Basic Support</li>
                            <li>? Community Forum Access</li>
                        </ul>
                        <a href="@Url.Action("ContactUs", "Home")" class="btn btn-primary d-block">Start Free Trial</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="card border-primary">
                    <div class="card-header bg-primary text-white">
                        <h3 class="text-center">Business</h3>
                    </div>
                    <div class="card-body">
                        <h4 class="text-center mb-3">?45,000<small>/month</small></h4>
                        <ul class="list-unstyled">
                            <li>? Up to 50,000 MAU</li>
                            <li>? 15 Social Login Providers</li>
                            <li>? Priority Support</li>
                            <li>? Advanced Security Features</li>
                        </ul>
                        <a href="@Url.Action("ContactUs", "Home")" class="btn btn-primary d-block">Contact Sales</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="card">
                    <div class="card-header">
                        <h3 class="text-center">Enterprise</h3>
                    </div>
                    <div class="card-body">
                        <h4 class="text-center mb-3">Custom</h4>
                        <ul class="list-unstyled">
                            <li>? Unlimited MAU</li>
                            <li>? All Social Login Providers</li>
                            <li>? 24/7 Premium Support</li>
                            <li>? Custom Integration Support</li>
                        </ul>
                        <a href="@Url.Action("ContactUs", "Home")" class="btn btn-primary d-block">Request Quote</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>