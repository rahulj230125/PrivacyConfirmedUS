@model PrivacyConfirmedModel.ContactUsModel
@{
    ViewData["Title"] = "Contact Us | PrivacyConfirmed";
}

<style>
    /* Contact Us Page Styling */
    .contact-hero {
        background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
        color: white;
        padding: 4rem 0 3rem 0;
        margin-bottom: 3rem;
    }
    
    .contact-hero h1 {
        font-weight: 700;
        font-size: 2.5rem;
        margin-bottom: 1rem;
    }
    
    .contact-hero p {
        font-size: 1.2rem;
        opacity: 0.95;
    }
    
    .contact-container {
        max-width: 800px;
        margin: 0 auto;
        padding-bottom: 5rem;
    }
    
    .contact-card {
        background: white;
        border-radius: 1rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        padding: 3rem;
        margin-bottom: 3rem;
    }
    
    .form-label {
        font-weight: 600;
        color: #212529;
        margin-bottom: 0.5rem;
    }
    
    .form-control {
        border: 2px solid #e9ecef;
        border-radius: 0.5rem;
        padding: 0.75rem 1rem;
        font-size: 1rem;
        transition: all 0.3s ease;
    }
    
    .form-control:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
    }
    
    .form-control.is-invalid {
        border-color: #dc3545;
    }
    
    .invalid-feedback {
        display: block;
        margin-top: 0.5rem;
        font-size: 0.875rem;
    }
    
    .btn-submit {
        background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
        border: none;
        padding: 1rem 3rem;
        font-size: 1.1rem;
        font-weight: 600;
        border-radius: 0.5rem;
        transition: all 0.3s ease;
    }
    
    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(13, 110, 253, 0.4);
    }
    
    .btn-submit:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }
    
    .contact-info-box {
        background: #f8f9fa;
        border-left: 4px solid #0d6efd;
        padding: 1.5rem;
        border-radius: 0.5rem;
        margin-bottom: 2rem;
    }
    
    .contact-info-box i {
        color: #0d6efd;
        font-size: 1.25rem;
        margin-right: 0.75rem;
    }
    
    .alert {
        border-radius: 0.5rem;
        border: none;
        padding: 1rem 1.5rem;
    }
    
    .required-asterisk {
        color: #dc3545;
        margin-left: 0.25rem;
    }
</style>

<!-- Submenu Navigation (above pill navigation) -->
<div class="container" style="padding-top: 3.5rem; padding-bottom:2.5rem">
    <div class="d-flex justify-content-center">
        <div style="background: #fff; box-shadow: 0 4px 24px rgba(0,0,0,0.10), 0 1.5px 4px rgba(0,0,0,0.08); border-radius: 3rem; padding: 0.5rem 1.5rem; display: inline-block;">
            <ul class="nav nav-pills justify-content-center" style="gap: 0.5rem;">
                <li class="nav-item">
                    <a class="round_sub_nav_button_in_active rounded-pill" asp-controller="Home" asp-action="About">About</a>
                </li>
                <li class="nav-item">
                    <a class="round_sub_nav_button_active card active rounded-pill" asp-controller="Home" asp-action="ContactUs">Contact Us</a>
                </li>
            </ul>
        </div>
    </div>
</div>
<div class="container contact-container">
    
    @* Display Error Messages *@
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <strong>Error:</strong> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    
    @* Display Validation Errors *@
    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i>
            <strong>Please correct the following errors:</strong>
            <ul class="mb-0 mt-2">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    
    <div class="contact-card">
        <div class="contact-info-box mb-4">
            <h5 class="mb-3">
                <i class="bi bi-info-circle-fill"></i>
                Why Contact Us?
            </h5>
            <ul class="mb-0">
                <li>Get a personalized demo of our IAM platform</li>
                <li>Discuss your enterprise security requirements</li>
                <li>Learn about pricing and implementation</li>
                <li>Technical support and consultation</li>
            </ul>
        </div>
        
        <form asp-action="ContactUs" method="post" id="contactForm">
            @Html.AntiForgeryToken()
            
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Name" class="form-label">
                        Full Name<span class="required-asterisk">*</span>
                    </label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0">
                            <i class="bi bi-person-fill text-primary"></i>
                        </span>
                        <input asp-for="Name" 
                               class="form-control border-start-0" 
                               placeholder="Enter your full name"
                               autocomplete="name"
                               required />
                    </div>
                    <span asp-validation-for="Name" class="text-danger invalid-feedback"></span>
                </div>
                
                <div class="col-md-6 mb-3">
                    <label asp-for="Company" class="form-label">
                        Company Name<span class="required-asterisk">*</span>
                    </label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0">
                            <i class="bi bi-building-fill text-primary"></i>
                        </span>
                        <input asp-for="Company" 
                               class="form-control border-start-0" 
                               placeholder="Enter your company name"
                               autocomplete="organization"
                               required />
                    </div>
                    <span asp-validation-for="Company" class="text-danger invalid-feedback"></span>
                </div>
            </div>
            
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="MobileNumber" class="form-label">
                        Mobile Number<span class="required-asterisk">*</span>
                    </label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0">
                            <i class="bi bi-phone-fill text-primary"></i>
                        </span>
                        <input asp-for="MobileNumber" 
                               class="form-control border-start-0" 
                               placeholder="10-digit mobile number"
                               type="tel"
                               pattern="[0-9]{10}"
                               maxlength="10"
                               autocomplete="tel"
                               required />
                    </div>
                    <span asp-validation-for="MobileNumber" class="text-danger invalid-feedback"></span>
                    <small class="text-muted">Please enter a 10-digit mobile number</small>
                </div>
                
                <div class="col-md-6 mb-3">
                    <label asp-for="Email" class="form-label">
                        Email Address<span class="required-asterisk">*</span>
                    </label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0">
                            <i class="bi bi-envelope-fill text-primary"></i>
                        </span>
                        <input asp-for="Email" 
                               class="form-control border-start-0" 
                               placeholder="your.email@company.com"
                               type="email"
                               autocomplete="email"
                               required />
                    </div>
                    <span asp-validation-for="Email" class="text-danger invalid-feedback"></span>
                </div>
            </div>
            
            <div class="mt-4 text-center">
                <button type="submit" class="btn-primary">
                    <i class="bi bi-send-fill me-2"></i>
                    Submit Request
                </button>
            </div>
            
            <div class="text-center mt-3">
                <small class="text-muted">
                    <i class="bi bi-shield-check me-1"></i>
                    Your information is secure and will only be used to contact you about your inquiry
                </small>
            </div>
        </form>
    </div>
    
    <div class="row g-4 mt-4">
        <div class="col-md-4">
            <div class="text-center p-4 bg-light rounded">
                <i class="bi bi-headset text-primary" style="font-size: 2.5rem;"></i>
                <h5 class="mt-3">Support</h5>
                <p class="text-muted mb-0">Available 24/7</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="text-center p-4 bg-light rounded">
                <i class="bi bi-clock-history text-primary" style="font-size: 2.5rem;"></i>
                <h5 class="mt-3">Quick Response</h5>
                <p class="text-muted mb-0">Within 24 hours</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="text-center p-4 bg-light rounded">
                <i class="bi bi-geo-alt-fill text-primary" style="font-size: 2.5rem;"></i>
                <h5 class="mt-3">India-Based</h5>
                <p class="text-muted mb-0">Local support team</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script>
        // Additional client-side validation and UX enhancements
        $(document).ready(function() {
            // Mobile number validation
            $('#MobileNumber').on('input', function() {
                this.value = this.value.replace(/[^0-9]/g, '');
                if (this.value.length > 10) {
                    this.value = this.value.slice(0, 10);
                }
            });
            
            // Form submission handling
            $('#contactForm').on('submit', function() {
                var submitBtn = $(this).find('button[type="submit"]');
                submitBtn.prop('disabled', true);
                submitBtn.html('<span class="spinner-border spinner-border-sm me-2"></span>Submitting...');
            });
            
            // Auto-dismiss alerts after 5 seconds
            setTimeout(function() {
                $('.alert').fadeOut('slow');
            }, 5000);
        });
    </script>
}
